<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="distributionHelpPage">
    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" imageSliceId="gui.icon_options_help2"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="Distribution - Help"/>
        </GuiElement>

        <!-- left: topic list (table of contents) -->
        <GuiElement profile="SDList" position="40px -96px" size="460px 760px">
            <SmoothList profile="SDList" id="topicList" position="0px 0px" size="460px 760px"
                        onSelectionChanged="onListSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="SDListItem" name="rowTemplate" size="460px 52px" onClick="onClickTopic">
                    <Text profile="SDRowCell" position="18px 0px" size="424px 52px" textSize="20px" name="topicName" />
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="fs25_listSliderBox" position="12px 0px" size="12px 760px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 752px" dataElementId="topicList" id="topicSlider" />
            </ThreePartBitmap>
        </GuiElement>

        <!-- right: selected topic body -->
        <GuiElement profile="SDList" position="540px -96px" size="1180px 760px">
            <SmoothList profile="SDList" id="bodyList" position="0px 0px" size="1180px 760px"
                        focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="SDBodyItem" name="rowTemplate" size="1180px 30px" onClick="onClickBodyRow">
                    <Text profile="SDBodyCell" position="6px 0px" size="1168px 30px" textSize="18px" name="bodyLine" />
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="fs25_listSliderBox" position="12px 0px" size="12px 760px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 752px" dataElementId="bodyList" id="bodyListSlider" />
            </ThreePartBitmap>
        </GuiElement>
    </GuiElement>
</GUI>
