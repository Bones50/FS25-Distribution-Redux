<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="distributionHusbandryPage">
    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" imageSliceId="gui.icon_options_gameSettings2"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="Distribution - Animal Husbandry"/>
        </GuiElement>

        <!-- left: building list -->
        <Bitmap profile="SDList" position="0px -46px" size="370px 40px">
            <Text profile="SDHeaderLeft" position="16px 0px" size="340px 40px" text="BARNS" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>
        <SmoothList profile="SDList" id="assetList" position="0px -90px" size="370px 800px"
                    onSelectionChanged="onListSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
            <ListItem profile="SDListItem" name="rowTemplate" size="370px 52px" onClick="onClickAsset">
                <Bitmap position="10px 6px" size="48px 40px" name="assetIcon" imageColor="1 1 1 1" />
                <Text profile="SDRowCell" position="66px 0px"  size="180px 52px" textSize="18px" name="assetName" />
                <Text profile="SDRowCell" position="252px 0px" size="106px 52px" textSize="15px" name="assetType" />
            </ListItem>
        </SmoothList>

        <!-- right: selected building detail -->
        <Text profile="SDHeaderLeft" id="assetTitleElement" position="390px -42px" size="1090px 36px" textSize="20px" text="" />

        <Bitmap profile="SDList" position="390px -90px" size="1090px 40px">
            <Text profile="SDHeaderLeft" position="44px 0px"  size="196px 40px" text="PRODUCT" />
            <Text profile="SDHeaderLeft" position="244px 0px" size="128px 40px" text="HELD (L)" />
            <Text profile="SDHeaderLeft" position="376px 0px" size="128px 40px" text="DISTR. /mo" />
            <Text profile="SDHeaderLeft" position="508px 0px" size="128px 40px" text="SOLD /mo" />
            <Text profile="SDHeaderLeft" position="640px 0px" size="128px 40px" text="STORED /mo" />
            <Text profile="SDHeaderLeft" position="772px 0px" size="318px 40px" text="OUTPUT TYPE" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>

        <SmoothList profile="SDList" id="detailList" position="390px -134px" size="1090px 756px"
                    focusChangeTop="nil" focusChangeBottom="nil">
            <ListItem profile="SDListItem" name="rowTemplate" size="1090px 52px" onClick="onClickDetailRow">
                <Bitmap position="12px 14px" size="24px 24px" name="fillIcon" imageColor="1 1 1 1" />
                <Text profile="SDRowCell" position="44px 0px"  size="196px 52px" textSize="18px" name="fillName" />
                <Text profile="SDRowCell" position="244px 0px" size="128px 52px" textSize="18px" name="heldText" />
                <Text profile="SDRowCell" position="376px 0px" size="128px 52px" textSize="18px" name="distText" />
                <Text profile="SDRowCell" position="508px 0px" size="128px 52px" textSize="18px" name="soldText" />
                <Text profile="SDRowCell" position="640px 0px" size="128px 52px" textSize="18px" name="storedText" />
                <Text profile="SDRowCell" position="772px 0px" size="318px 52px" textSize="18px" name="modeText" />
            </ListItem>
        </SmoothList>

        <ThreePartBitmap profile="fs25_listSliderBox" position="1485px -134px" size="12px 756px">
            <Slider profile="fs25_listSlider" size="6px 748px" dataElementId="detailList" id="detailSlider" />
        </ThreePartBitmap>
    </GuiElement>
</GUI>
