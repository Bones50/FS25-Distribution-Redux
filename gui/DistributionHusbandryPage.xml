<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="distributionHusbandryPage">
    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" imageSliceId="gui.icon_ingameMenu_animals"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="Distribution - Animal Husbandry"/>
        </GuiElement>

        <!-- left: husbandry list -->
        <Bitmap profile="SDList" position="0px -46px" size="370px 40px">
            <Text profile="SDHeaderLeft" position="16px 0px" size="340px 40px" text="HUSBANDRIES" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>
        <SmoothList profile="SDList" id="assetList" position="0px -90px" size="370px 720px"
                    onSelectionChanged="onListSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
            <ListItem profile="SDListItem" name="rowTemplate" size="370px 52px" onClick="onClickAsset">
                <Bitmap position="10px 6px" size="48px 40px" name="assetIcon" imageColor="1 1 1 1" />
                <!-- renamed buildings: player's name on top, original store name beneath (positive Y = up) -->
                <Text profile="SDRowCell" position="66px 10px"  size="180px 26px" textSize="17px" name="assetName" />
                <Text profile="SDRowCell" position="66px -12px" size="180px 20px" textSize="13px" name="assetOrigName" />
                <Text profile="SDRowCell" position="252px 0px" size="106px 52px" textSize="15px" name="assetType" />
            </ListItem>
        </SmoothList>

        <!-- right: incoming products (inputs / demand) -->
        <Bitmap profile="SDList" position="390px -46px" size="1090px 40px">
            <Text profile="SDHeaderLeft" position="44px 0px"  size="280px 40px" text="Incoming Products" />
            <Text profile="SDHeaderLeft" position="330px 0px" size="180px 40px" text="RECEIVED /mo" />
            <Text profile="SDHeaderLeft" position="520px 0px" size="180px 40px" text="CONSUMED /mo" />
            <Text profile="SDHeaderLeft" position="710px 0px" size="160px 40px" text="HELD (L)" />
            <Text profile="SDHeaderLeft" position="880px 0px" size="200px 40px" text="DISTRIBUTION" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>
        <GuiElement profile="SDList" position="390px -90px" size="1090px 300px">
            <SmoothList profile="SDList" id="inputList" position="0px 0px" size="1090px 300px"
                        onSelectionChanged="onInputSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="SDListItem" name="rowTemplate" size="1090px 52px" onClick="onClickInputRow">
                    <Bitmap position="12px 14px" size="24px 24px" name="fillIcon" imageColor="1 1 1 1" />
                    <Text profile="SDRowCell" position="44px 0px"  size="280px 52px" textSize="18px" name="fillName" />
                    <Text profile="SDRowCell" position="330px 0px" size="180px 52px" textSize="18px" name="recvText" />
                    <Text profile="SDRowCell" position="520px 0px" size="180px 52px" textSize="18px" name="consumedText" />
                    <Text profile="SDRowCell" position="710px 0px" size="160px 52px" textSize="18px" name="heldText" />
                    <Text profile="SDRowCell" position="880px 0px" size="200px 52px" textSize="16px" name="statusText" />
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="fs25_listSliderBox" position="12px 0px" size="12px 300px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 292px" dataElementId="inputList" id="inputSlider" />
            </ThreePartBitmap>
        </GuiElement>

        <!-- outgoing products (outputs) -->
        <Bitmap profile="SDList" position="390px -430px" size="1090px 40px">
            <Text profile="SDHeaderLeft" position="44px 0px"  size="150px 40px" text="Outgoing Products" />
            <Text profile="SDHeaderLeft" position="200px 0px" size="110px 40px" text="PRODUCED /mo" />
            <Text profile="SDHeaderLeft" position="314px 0px" size="110px 40px" text="DISTR. /mo" />
            <Text profile="SDHeaderLeft" position="428px 0px" size="110px 40px" text="STORED /mo" />
            <Text profile="SDHeaderLeft" position="542px 0px" size="130px 40px" text="SOLD /mo" />
            <Text profile="SDHeaderLeft" position="676px 0px" size="140px 40px" text="HELD (L)" />
            <Text profile="SDHeaderLeft" position="820px 0px" size="270px 40px" text="MODE" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>
        <GuiElement profile="SDList" position="390px -474px" size="1090px 336px">
            <SmoothList profile="SDList" id="outputList" position="0px 0px" size="1090px 336px"
                        onSelectionChanged="onListSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="SDListItem" name="rowTemplate" size="1090px 52px" onClick="onClickOutputRow">
                    <Bitmap position="12px 14px" size="24px 24px" name="fillIcon" imageColor="1 1 1 1" />
                    <Text profile="SDRowCell" position="44px 0px"  size="150px 52px" textSize="18px" name="fillName" />
                    <Text profile="SDRowCell" position="200px 0px" size="110px 52px" textSize="18px" name="prodText" />
                    <Text profile="SDRowCell" position="314px 0px" size="110px 52px" textSize="18px" name="distText" />
                    <Text profile="SDRowCell" position="428px 0px" size="110px 52px" textSize="18px" name="storedText" />
                    <Text profile="SDRowCell" position="542px 0px" size="130px 52px" textSize="18px" name="soldText" />
                    <Text profile="SDRowCell" position="676px 0px" size="140px 52px" textSize="18px" name="heldText" />
                    <Text profile="SDRowCell" position="820px 0px" size="270px 52px" textSize="18px" name="modeText" />
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="fs25_listSliderBox" position="12px 0px" size="12px 336px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 328px" dataElementId="outputList" id="outputSlider" />
            </ThreePartBitmap>
        </GuiElement>
    </GuiElement>
</GUI>
