<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="distributionStoragePage">
    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" imageSliceId="gui.icon_options_gameSettings2"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="Distribution - Storage"/>
        </GuiElement>

        <!-- left: building list -->
        <Bitmap profile="SDList" position="0px -46px" size="370px 40px">
            <Text profile="SDHeaderLeft" position="16px 0px" size="340px 40px" text="BUILDINGS" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>
        <SmoothList profile="SDList" id="assetList" position="0px -90px" size="370px 720px"
                    onSelectionChanged="onListSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
            <ListItem profile="SDListItem" name="rowTemplate" size="370px 52px" onClick="onClickAsset">
                <Bitmap position="10px 6px" size="48px 40px" name="assetIcon" imageColor="1 1 1 1" />
                <!-- renamed buildings: player's name on top, original store name beneath (positive Y = up) -->
                <Text profile="SDRowCell" position="66px 10px"  size="180px 26px" textSize="17px" name="assetName" />
                <Text profile="SDRowCell" position="66px -12px" size="180px 20px" textSize="13px" name="assetOrigName" />
                <Text profile="SDRowCell" position="252px 0px" size="106px 52px" textSize="15px" name="assetType" />
            </ListItem>
        </SmoothList>

        <!-- right: INCOMING PRODUCTS (inputs). Same products the building can hold, with the Animal
             Husbandry column set; rows are selectable, ready for the input drill-down. -->
        <Bitmap profile="SDList" position="390px -46px" size="1090px 40px">
            <Text profile="SDHeaderLeft" position="44px 0px"  size="300px 40px" text="INCOMING PRODUCTS" />
            <Text profile="SDHeaderLeft" position="360px 0px" size="220px 40px" text="RECEIVED /mo" />
            <Text profile="SDHeaderLeft" position="620px 0px" size="230px 40px" text="HELD (L)" />
            <Text profile="SDHeaderLeft" position="860px 0px" size="220px 40px" text="DISTRIBUTION" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>
        <GuiElement profile="SDList" position="390px -90px" size="1090px 300px">
            <SmoothList profile="SDList" id="inputList" position="0px 0px" size="1090px 300px"
                        onSelectionChanged="onInputSelectionChanged" focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="SDListItem" name="rowTemplate" size="1090px 52px" onClick="onClickInputRow">
                    <Bitmap position="12px 14px" size="24px 24px" name="fillIcon" imageColor="1 1 1 1" />
                    <Text profile="SDRowCell" position="44px 0px"  size="300px 52px" textSize="18px" name="fillName" />
                    <Text profile="SDRowCell" position="360px 0px" size="220px 52px" textSize="18px" name="recvText" />
                    <Text profile="SDRowCell" position="620px 0px" size="230px 52px" textSize="18px" name="heldText" />
                    <Text profile="SDRowCell" position="860px 0px" size="220px 52px" textSize="16px" name="statusText" />
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="fs25_listSliderBox" position="12px 0px" size="12px 300px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 292px" dataElementId="inputList" id="inputSlider" />
            </ThreePartBitmap>
        </GuiElement>

        <!-- OUTGOING PRODUCTS (outputs; carries the mode + send status) -->
        <Bitmap profile="SDList" position="390px -430px" size="1090px 40px">
            <Text profile="SDHeaderLeft" position="44px 0px"  size="186px 40px" text="OUTGOING PRODUCTS" />
            <Text profile="SDHeaderLeft" position="232px 0px" size="110px 40px" text="HELD (L)" />
            <Text profile="SDHeaderLeft" position="344px 0px" size="110px 40px" text="DISTR. /mo" />
            <Text profile="SDHeaderLeft" position="456px 0px" size="124px 40px" text="SOLD /mo" />
            <Text profile="SDHeaderLeft" position="582px 0px" size="110px 40px" text="STORED /mo" />
            <Text profile="SDHeaderLeft" position="694px 0px" size="196px 40px" text="OUTPUT TYPE" />
            <Text profile="SDHeaderLeft" position="892px 0px" size="198px 40px" text="STATUS" />
            <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px 2px" />
        </Bitmap>

        <GuiElement profile="SDList" position="390px -474px" size="1090px 336px">
            <SmoothList profile="SDList" id="detailList" position="0px 0px" size="1090px 336px"
                        focusChangeTop="nil" focusChangeBottom="nil">
                <ListItem profile="SDListItem" name="rowTemplate" size="1090px 52px" onClick="onClickDetailRow">
                    <Bitmap position="12px 14px" size="24px 24px" name="fillIcon" imageColor="1 1 1 1" />
                    <Text profile="SDRowCell" position="44px 0px"  size="186px 52px" textSize="18px" name="fillName" />
                    <Text profile="SDRowCell" position="232px 0px" size="110px 52px" textSize="18px" name="heldText" />
                    <Text profile="SDRowCell" position="344px 0px" size="110px 52px" textSize="18px" name="distText" />
                    <Text profile="SDRowCell" position="456px 0px" size="124px 52px" textSize="18px" name="soldText" />
                    <Text profile="SDRowCell" position="582px 0px" size="110px 52px" textSize="18px" name="storedText" />
                    <Text profile="SDRowCell" position="694px 0px" size="196px 52px" textSize="18px" name="modeText" />
                    <Text profile="SDRowCell" position="892px 0px" size="198px 52px" textSize="16px" name="statusText" />
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="fs25_listSliderBox" position="12px 0px" size="12px 336px" with="anchorTopRight">
                <Slider profile="fs25_listSlider" size="6px 328px" dataElementId="detailList" id="detailSlider" />
            </ThreePartBitmap>
        </GuiElement>
    </GuiElement>
</GUI>
